---
interface Props {
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const { title: titleProp, description: descProp, frontmatter } = Astro.props as Props;
const title = titleProp ?? frontmatter?.title ?? 'John Steve — Clarinette';
const description = descProp ?? frontmatter?.description ?? "John Steve, clarinettiste. Cours, concerts et enregistrements.";
const base = import.meta.env.BASE_URL;

const navItems = [
  { href: base, label: 'Accueil' },
  { href: `${base}biographie/`, label: 'Biographie' },
  { href: `${base}contact/`, label: 'Contact' },
  { href: `${base}photos/`, label: 'Photos' },
  { href: `${base}enregistrements/`, label: 'Vidéos / Enregistrements' },
  { href: `${base}duo-salazar-tcherkasskaia/`, label: 'Duo Salazar - Tcherkasskaia' },
  { href: `${base}concerts/`, label: 'Concerts' },
  { href: `${base}calendrier/`, label: 'Calendrier' },
  { href: `${base}commentaires/`, label: 'Commentaires' },
  { href: `${base}eleves-de-clarinette/`, label: 'Elèves de clarinette' },
];
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        {navItems.map(({ href, label }) => (
          <a href={href}>{label}</a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>John Steve — Clarinette</p>
      <p class="copyright">© {new Date().getFullYear()} Musique Classique</p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
  :root {
    --color-bg: #0f0f0f;
    --color-surface: #1a1a1a;
    --color-text: #f0f0f0;
    --color-accent: #c9a227;
    --font-sans: 'Segoe UI', system-ui, sans-serif;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  main {
    flex: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
  }
  header {
    background: var(--color-surface);
    border-bottom: 1px solid rgba(201, 162, 39, 0.2);
    padding: 1rem 1.5rem;
  }
  header nav {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  header nav a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
  }
  header nav a:hover {
    color: var(--color-accent);
  }
  footer {
    background: var(--color-surface);
    text-align: center;
    padding: 1.5rem;
    font-size: 0.9rem;
    color: #888;
  }
  footer .copyright {
    margin: 0.25rem 0 0;
    font-size: 0.85rem;
  }
  main :global(h1) {
    font-size: 1.75rem;
    margin: 0 0 1rem;
  }
  main :global(h2) {
    font-size: 1.2rem;
    margin: 2rem 0 0.5rem;
  }
  main :global(h2:first-of-type) {
    margin-top: 0;
  }
  main :global(p) {
    margin: 0 0 1rem;
    color: #e0e0e0;
  }
  main :global(.contact-info) {
    background: var(--color-surface);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }
  main :global(.contact-info a) {
    color: var(--color-accent);
    text-decoration: none;
  }
  main :global(.contact-info a:hover) {
    text-decoration: underline;
  }
  main :global(.testimonial) {
    margin-bottom: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  main :global(.testimonial:last-of-type) {
    border-bottom: none;
  }
</style>
