---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const contactImage = `${base}images/_vi_hBh00LRP1uY_maxresdefault.jpg`;
---

<Layout title="Contact — John Steve Clarinette" description="Contactez John Steve, clarinettiste. E-mail et téléphone.">
  <h1>Contact</h1>
  <div class="contact-image-wrapper">
    <img
      src={contactImage}
      alt="Contact"
      width={1280}
      height={720}
      class="contact-image"
      loading="lazy"
    />
  </div>
  <p>
    Veuillez m'envoyer un e-mail ou me contacter par téléphone, je vous répondrai rapidement.
  </p>
  <div class="contact-info">
    <h2>Contact par téléphone</h2>
    <p>
      <a href="tel:+33636254348">T : 00 33 (0)6 36 25 43 48</a>
    </p>
    <h2>Contact par e-mail</h2>
    <p>
      <a href="mailto:johnstevesg@gmail.com">Envoyez un e-mail</a>
    </p>
  </div>
</Layout>

<style>
  .contact-image-wrapper {
    width: 100%;
    max-width: 640px;
    margin: 1.5rem auto;
    border-radius: 8px;
    overflow: hidden;
  }
  .contact-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  .contact-info {
    margin-top: 1.5rem;
  }
</style>
